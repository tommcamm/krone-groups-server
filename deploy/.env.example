# Operator configuration for the docker-compose deployment.

# Hostname that Let's Encrypt will issue a certificate for.
DOMAIN=groups.example.com

# Email used by Caddy for ACME registration.
TLS_EMAIL=ops@example.com

# Optional: 32-byte hex seed for the server's Ed25519 keypair. Leave empty to let the
# container generate a fresh seed on first boot (persisted in the `server_data` volume).
# If you set this, keep it secret — anyone with this seed can impersonate your server.
# Generate one with:  openssl rand -hex 32
KRONE_SERVER_SEED=

# Tracing level: error | warn | info | debug | trace
RUST_LOG=info
