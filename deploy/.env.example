# Operator configuration for the docker-compose deployment.

# Public hostname clients will connect to.
DOMAIN=groups.example.com

# TLS strategy:
#   letsencrypt  (default) — Caddy obtains and renews a Let's Encrypt cert.
#                            Requires ports 80 + 443 reachable from the public
#                            internet and a valid TLS_EMAIL below.
#   custom                  — Mount your own cert at deploy/certs/fullchain.pem
#                            + deploy/certs/privkey.pem. Used for Cloudflare
#                            Origin CA, internal PKI, or any non-ACME source.
KRONE_TLS_MODE=letsencrypt

# ACME registration email. Only used when KRONE_TLS_MODE=letsencrypt; leave
# empty in custom mode.
TLS_EMAIL=ops@example.com

# Optional: 32-byte hex seed for the server's Ed25519 keypair. Leave empty to let the
# container generate a fresh seed on first boot (persisted in the `server_data` volume).
# If you set this, keep it secret — anyone with this seed can impersonate your server.
# Generate one with:  openssl rand -hex 32
KRONE_SERVER_SEED=

# Tracing level: error | warn | info | debug | trace
RUST_LOG=info
